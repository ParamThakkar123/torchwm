{
  "name": "torchwm-desktop",
  "version": "0.1.0",
  "description": "TorchWM Desktop - World Models Training Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "TorchWM",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.torchwm.desktop",
    "productName": "TorchWM Desktop",
    "asar": true,
    "asarUnpack": "**/*.node",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "torchwm",
      "repo": "torchwm"
    },
    "directories": {
      "output": "dist-new"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../torchwm_ui/dist",
        "to": "web-ui",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "useZip": false
    }
  }
}
